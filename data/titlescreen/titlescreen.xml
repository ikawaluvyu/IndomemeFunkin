<!DOCTYPE codename-titlestate>
<titlestate>
	<sprites folder="menus/titlescreen">
		<sprite name="logo" sprite="logo" x="315" y="-20" scale="0.4" updateHitbox="true"/>

		<titleEnter sprite="titleEnter" x="-150" y="-100" />
	</sprites>

	<intro length="16">
		<text beat="1">
			<line text="ninjamuffin99" />
			<line text="phantomArcade" />
			<line text="kawaisprite" />
			<line text="evilsk8er" />
			<line text="presents" />
		</text>

		<text beat="3" /> <!-- clears the screen !-->

		<text beat="4">
			<line text="In association" />
			<line text="with" />
		</text>

		<text beat="6">
			<line text="In association" />
			<line text="with" />
			<line text="Newgrounds" />
			<sprite path="menus/titlescreen/newgrounds_logo" scale="0.8"/>
		</text>

		<text beat="7" /> <!-- clears the screen !-->

		<text beat="8">
			<introtext line="1" />
		</text>

		<text beat="10">
			<introtext line="1" />
			<introtext line="2" />
		</text>

		<text beat="11" />

		<text beat="12">
			<line text=" " />
			<line text="Indo" />
		</text>

		<text beat="13">
			<line text=" " />
			<line text="Indomeme" />
		</text>

		<text beat="14">
			<line text=" " />
			<line text="Indomeme" />
			<line text="Funkin" />
		</text>

		<text beat="15"/>
	</intro>
</titlestate>